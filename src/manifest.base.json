{
  "manifest_version": 3,
  "name": "Vault Keeper",
  "version": "0.1.0",
  "description": "Intelligent vault cleanup companion for Destiny Item Manager. Stage gear to Trash; never dismantles in-game items.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.destinyitemmanager.com/*",
    "*://destinyitemmanager.com/*",
    "https://openrouter.ai/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.destinyitemmanager.com/*",
        "*://destinyitemmanager.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
