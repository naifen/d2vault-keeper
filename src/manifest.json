{
  "manifest_version": 3,
  "name": "Vault Keeper",
  "version": "0.1.0",
  "description": "Intelligent vault cleanup companion for Destiny Item Manager. Stage gear to Trash; never dismantles in-game items.",
  "browser_specific_settings": {
    "gecko": {
      "id": "vault-keeper@d2vault-keeper.local",
      "strict_min_version": "121.0"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.destinyitemmanager.com/*",
    "*://destinyitemmanager.com/*",
    "https://openrouter.ai/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://localhost/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.destinyitemmanager.com/*",
        "*://destinyitemmanager.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "sidebar_action": {
    "default_title": "Vault Keeper",
    "default_panel": "workbench.html",
    "open_at_install": false
  },
  "action": {
    "default_title": "Vault Keeper",
    "default_area": "navbar"
  },
  "commands": {
    "_execute_sidebar_action": {
      "description": "Open Vault Keeper Workbench"
    }
  }
}
