###############################################################################
# AI coding agents — local/private state only
#
# Do not blanket-ignore .claude/, .codex/, .opencode/, .pi/, etc.
# Those directories may contain intentional, team-shared project config.
###############################################################################

# Claude Code
.claude/settings.local.json
.claude/*.local.json
.claude/**/*.local.json
.claude/settings.json
.claude/commands/
.claude/rules/
.claude/skills/

# Generic per-user agent overrides
AGENTS.local.md
CLAUDE.local.md
CODEX.local.md
GEMINI.local.md
GROK.local.md
OPENCODE.local.md
PI.local.md

.agents/agents/
.agents/commands/
.agents/rules/
.agents/skills/

